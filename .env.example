# MuxCore Module — Environment Variables
# Copy to .env and adjust for your environment.

# Core connection
# MUXCORE_GRPC_ADDR=localhost:9090
# MUXCORE_INSECURE_DISABLE_TLS=true

# Module identity
# MUXCORE_MODULE_ID=your-module

# Module-specific settings
# YOUR_MODULE_ADDR=:9400
# YOUR_MODULE_LOG_LEVEL=info
